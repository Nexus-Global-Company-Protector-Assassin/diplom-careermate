{
    "name": "@careermate/agent",
    "version": "1.0.0",
    "description": "CareerMate Agent Service - MCP & LLM",
    "private": true,
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "eval": "npx ts-node src/agent/eval/run-eval.ts",
        "seed": "npx ts-node src/agent/scripts/seed-vacancies.ts",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.1",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.1.1",
        "@nestjs/core": "^10.3.0",
        "@nestjs/platform-express": "^10.3.0",
        "@pinecone-database/pinecone": "^7.2.0",
        "@types/uuid": "^11.0.0",
        "axios": "^1.6.5",
        "ioredis": "^5.10.1",
        "mammoth": "^1.12.0",
        "multer": "^2.1.1",
        "pdf-parse": "^1.1.1",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.1",
        "uuid": "^13.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.2.1",
        "@nestjs/schematics": "^10.0.3",
        "@nestjs/testing": "^10.3.0",
        "@types/express": "^4.17.25",
        "@types/jest": "^29.5.11",
        "@types/multer": "^2.1.0",
        "@types/node": "^20.10.6",
        "@types/pdf-parse": "^1.1.5",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "source-map-support": "^0.5.21",
        "ts-jest": "^29.1.1",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "testEnvironment": "node"
    }
}