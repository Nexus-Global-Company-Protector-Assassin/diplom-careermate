# ============================================================
# CareerMate — Production Environment Template
# ============================================================
# Copy this file to /opt/careermate/.env.production on your VPS
# and fill in all values. NEVER commit .env.production to git.
# ============================================================

# ── Docker images (set by deploy.yml automatically, or fill manually) ──
FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_ORG/careermate-frontend:latest
BACKEND_IMAGE=ghcr.io/YOUR_GITHUB_ORG/careermate-backend:latest
AGENT_IMAGE=ghcr.io/YOUR_GITHUB_ORG/careermate-agent:latest

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=careermate
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=careermate_prod
DATABASE_URL=postgresql://careermate:CHANGE_ME_strong_password_here@postgres:5432/careermate_prod?schema=public

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379

# ── JWT (generate with: openssl rand -base64 64) ────────────
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_min_32_chars
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# ── Google OAuth ─────────────────────────────────────────────
# Add http://YOUR_VPS_IP/auth/google/callback to Google Console
# → APIs & Services → Credentials → OAuth 2.0 Client → Authorized redirect URIs
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://YOUR_VPS_IP/auth/google/callback

# ── Frontend (Vercel URL) ────────────────────────────────────
FRONTEND_URL=https://YOUR_PROJECT.vercel.app
CORS_ORIGIN=https://YOUR_PROJECT.vercel.app

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=CareerMate <onboarding@resend.dev>

# ── LLM (Polza.ai / OpenAI-compatible) ──────────────────────
LLM_API_BASE_URL=https://polza.ai/api/v1
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL_NAME=google/gemini-2.0-flash
LLM_MODEL_NAME_FAST=google/gemini-2.0-flash-lite
LLM_MODEL_NAME_SMART=google/gemini-2.0-pro
EMBEDDINGS_MODEL_NAME=text-embedding-3-small
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=3

# ── Qdrant (cloud.qdrant.io) ─────────────────────────────────
QDRANT_URL=https://YOUR_CLUSTER_ID.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=YOUR_QDRANT_API_KEY
QDRANT_COLLECTION=careermate-vacancies

# ── Neo4j AuraDB ─────────────────────────────────────────────
NEO4J_URI=neo4j+s://YOUR_INSTANCE_ID.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=YOUR_NEO4J_PASSWORD
NEO4J_DATABASE=neo4j

# ── Object Storage ───────────────────────────────────────────
# Use MinIO self-hosted, Cloudflare R2, or AWS S3
STORAGE_ENDPOINT=https://YOUR_MINIO_OR_S3_ENDPOINT
STORAGE_ACCESS_KEY=YOUR_STORAGE_ACCESS_KEY
STORAGE_SECRET_KEY=YOUR_STORAGE_SECRET_KEY
STORAGE_BUCKET=careermate-storage

# ── Adzuna job search API ────────────────────────────────────
ADZUNA_APP_ID=YOUR_ADZUNA_APP_ID
ADZUNA_APP_KEY=YOUR_ADZUNA_APP_KEY
ADZUNA_COUNTRY=gb

# ── Freemium quotas ──────────────────────────────────────────
QUOTA_AI_DAILY=10
QUOTA_RESUMES=3
QUOTA_QUIZ=3
