// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String?
  oauthProvider         String?
  oauthId               String?
  subscriptionTier      String    @default("free")
  subscriptionExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastLoginAt           DateTime?
  hashedRefreshToken    String?

  profile               Profile?
}

model Profile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String?
  phone               String?
  location            String?
  desiredPosition     String?
  desiredSalaryMin    Int?
  desiredSalaryMax    Int?
  experienceYears     Int?
  education           Json?
  workExperience      Json?
  skills              Json?
  languages           Json?
  aboutMe             String?
  careerGoals         String?
  linkedinUrl         String?
  githubUrl           String?
  portfolioUrl        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  analysisResults     AnalysisResult[]
  resumes             Resume[]
  interviews          Interview[]
  vacancyResponses    VacancyResponse[]
}

model AnalysisResult {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  content   Json     // Full analysis result from Agent
  createdAt DateTime @default(now())
}

model Resume {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  title     String   @default("Мое резюме")
  subtitle  String?  
  content   String   // Markdown or HTML content
  status    String   @default("draft") // draft, active, archived
  type      String   @default("resume") // resume, cover_letter, ai_improved
  version   Int      @default(1)
  reviewData Json?   // Full AI review result (score, strengths, weaknesses, improved resume)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Interview {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  company   String
  position  String
  date      String
  time      String
  type      String?  @default("online")
  location  String?
  status    String   @default("upcoming") // upcoming, completed, canceled, rejected
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VacancyResponse {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  vacancyId   String?  // Reference to external or internal Vacancy
  company     String
  position    String
  status      String   @default("sent") // sent, viewing, invited, rejected
  statusColor String   @default("bg-blue-500")
  responseDate DateTime @default(now())
}

model Vacancy {
  id                 String   @id @default(uuid())
  hhId               String   @unique  // ID вакансии на HH.ru
  title              String
  employer           String
  location           String?
  salaryFrom         Int?
  salaryTo           Int?
  salaryCurrency     String?
  salaryLabel        String?
  skills             Json?    // Массив ключевых навыков
  descriptionPreview String?
  experience         String?
  schedule           String?
  url                String?  // Ссылка на оригинальную вакансию
  searchQuery        String   // Поисковый запрос, по которому найдена вакансия
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
