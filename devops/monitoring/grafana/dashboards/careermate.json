{
  "title": "CareerMate — Overview",
  "uid": "careermate-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["careermate"],
  "panels": [
    {
      "id": 1,
      "title": "Backend Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"careermate-backend\"}",
          "legendFormat": "Backend"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "PostgreSQL Status",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"postgres\"}",
          "legendFormat": "PostgreSQL"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Redis Status",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"redis\"}",
          "legendFormat": "Redis"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Requests / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{job=\"careermate-backend\"}[1m])",
          "legendFormat": "{{method}} {{route}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"careermate-backend\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"careermate-backend\"}[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 6,
      "title": "Node.js Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"careermate-backend\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=\"careermate-backend\"}",
          "legendFormat": "Heap Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 7,
      "title": "Node.js Event Loop Lag",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "rate(nodejs_eventloop_lag_seconds_sum{job=\"careermate-backend\"}[1m])",
          "legendFormat": "Event Loop Lag"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "title": "Active HTTP Connections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 7 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{job=\"careermate-backend\"}",
          "legendFormat": "Active Handles"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area"
      }
    },
    {
      "id": 9,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"postgres\"}",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 11,
      "title": "Host CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "min": 0 }
      }
    },
    {
      "id": 12,
      "title": "Host Memory Usage",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ]
}
